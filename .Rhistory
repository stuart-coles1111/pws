simulate_race <- function(ratings = c(10, 40, 20, 60, 25, 30)) {
df <- data.frame(
horse = 1:6,
ratings = ratings
)
df_left <- df
place <- c()
for (i in 1:5) {
place[i] <- sample(
df_left$horse,
1,
prob = df_left$ratings
)
df_left <- subset(
df_left,
horse != place[i]
)
}
place <- c(place, df_left$horse)
Sys.sleep(5)
return(place)
}
simulate_race()
generate_scenario <- function(
n_races = 50,
a = 1
) {
ratings <- as.numeric(
gtools::rdirichlet(
1,
rep(a, 6)
)
)
results <- t(
replicate(
n_races,
simulate_horse_race(ratings)
)
)
results <- data.frame(
race = 1:n_races,
results
)
names(results) <- c(
"race",
"1st",
"2nd",
"3rd",
"4th",
"5th",
"6th"
)
list(
ratings = ratings,
history = results
)
}
generate_scenario()

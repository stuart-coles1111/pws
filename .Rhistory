if (input$vector_mode == "simulate") {
sim <- sim_details()
if (is.null(sim)) {
data_code <- paste(
"# Generate data using:",
"set.seed(<seed>)",
"nsim <- <number of observations>",
"lambda <- runif(1, 2, 20)",
"x <- rpois(nsim, lambda)",
sep = "\n"
)
} else {
data_code <- paste(
paste0("set.seed(", sim$seed, ")"),
"",
paste0("nsim <- ", sim$n),
"",
paste0("lambda <- ", round(sim$lambda, 4)),
"",
"x <- rpois(",
"    nsim,",
"    lambda",
")",
sep = "\n"
)
}
} else {
vals <- toolkit_data()$data
data_code <- paste0(
"x <- c(",
paste(head(vals, 20), collapse = ", "),
if (length(vals) > 20) ", ..." else "",
")"
)
}
